# AI HealthHack backend environment (example)
# Copy to .env and fill in real values. Do not commit .env.

APP_NAME="AI HealthHack Backend"
ENVIRONMENT=development

# Frontend origins allowed to call this API (comma separated).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173,http://127.0.0.1:4173

# Supabase project (used for JWT verification and record persistence).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
# Optional fixed patient UUID for the synthetic demo profile.
DEMO_PATIENT_ID=

# Hugging Face Gemma (required for NDIS plan, patient chat, and document extraction).
HF_TOKEN=
HD_MODEL=google/gemma-4-26B-A4B-it:novita
